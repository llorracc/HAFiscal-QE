# .dockerignore for HAFiscal-Public
# Exclude files that shouldn't be in the Docker image

# Build artifacts
*.aux
*.log
*.out
*.toc
*.bbl
*.blg
*.fdb_latexmk
*.synctex.gz
*.pdf

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
.venv/
venv/
env/

# Git
.git/
.gitignore
.gitattributes

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Documentation that's not needed in container
*.md
!README.md

# Large data files (if any)
*.obj
*.csv
*.dat

# Temporary files
*.tmp
*.bak

